{
  "name": "@forgedevstack/bear",
  "version": "1.2.4",
  "description": "Strong, reliable React UI components. AeroCraft-powered, zero config required. The protective force of ForgeStack.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "require": "./dist/context/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/base.css": "./dist/styles/_base.css",
    "./styles/buttons.css": "./dist/styles/_buttons.css",
    "./styles/alerts.css": "./dist/styles/_alerts.css",
    "./styles/effects.css": "./dist/styles/_effects.css",
    "./styles/marquee.css": "./dist/styles/_marquee.css",
    "./postcss": "./dist/postcss/bear-plugin.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && npm run build:css && npm run build:modules",
    "build:css": "postcss ./src/styles/main.css -o ./dist/styles.css",
    "build:modules": "cp -r src/styles dist/styles && cp -r src/postcss dist/postcss",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "portal": "cd portal && npm run dev",
    "portal:install": "cd portal && npm install",
    "portal:build": "cd portal && npm run build",
    "sanity": "bash scripts/pre-commit.sh",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ],
    "portal/src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@forgedevstack/aerocraft": "^1.0.4",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@forgedevstack/anvil": "^1.0.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "aerocraft",
    "typescript",
    "forge",
    "bear",
    "design-system"
  ],
  "author": "John Yaghobieh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yaghobieh/bear",
    "directory": "packages/ember"
  },
  "homepage": "https://bearui.com",
  "bugs": {
    "url": "https://github.com/yaghobieh/bear/issues"
  }
}
